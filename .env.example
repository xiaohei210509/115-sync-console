# Required: the 115 directory CID to scan.
SYNC_ROOT_CID=

# Remote root display name and local download destination.
SYNC_ROOT_NAME=Media
SYNC_DOWNLOAD_DIR=/srv/media
SYNC_APP_HOME=/var/lib/115-sync-console

# Comma-separated remote paths, relative to the selected root.
# Include the root name in each path, for example Media/Downloads.
SYNC_EXCLUDE_PREFIXES=Media/Downloads,Media/__cdtest__
SYNC_INCLUDE_PREFIX=
SYNC_PRIORITY_KEYWORDS=

# Dashboard. Generate a long random token before exposing write actions.
SYNC_DASHBOARD_HOST=127.0.0.1
SYNC_DASHBOARD_PORT=8090
SYNC_ADMIN_TOKEN=replace-with-a-long-random-token

# Downloader tuning.
SYNC_FILE_WORKERS=4
SYNC_RANGE_WORKERS=3
SYNC_PART_CHUNK_MIB=256
SYNC_LIST_PAGE_SIZE=32
SYNC_SCAN_PAGE_DELAY=8
SYNC_SCAN_DIR_DELAY=20
